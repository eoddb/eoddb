# Cloudflare Pages appends every matching rule's headers, so rules are kept
# mutually exclusive: ":file" matches exactly one path segment (pages, JS,
# JSON directly under a game dir), while the img/* splats catch the deeper
# image paths. Content revalidates every load (cheap ETag 304s); images
# cache for a day. Requires the zone's Browser Cache TTL to be "Respect
# Existing Headers" (set 2026-07-22) or CF overrides the .js responses.

/
  Cache-Control: no-cache

/:page
  Cache-Control: no-cache

/hna/:file
  Cache-Control: no-cache

/poe2/:file
  Cache-Control: no-cache

/hsr/:file
  Cache-Control: no-cache

/hna/img/*
  Cache-Control: public, max-age=86400

/poe2/img/*
  Cache-Control: public, max-age=86400

/hsr/img/*
  Cache-Control: public, max-age=86400
